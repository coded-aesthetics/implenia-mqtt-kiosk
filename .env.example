# ==================================================
# Implenia Kiosk — Environment Configuration
# ==================================================
# Copy this file to .env and fill in the values.
# All variables without defaults are REQUIRED.
# ==================================================

# --- MQTT Broker ---
MQTT_BROKER_URL=mqtt://192.168.1.50:1883
MQTT_TOPICS=sensors/#

# --- Implenia REST API ---
IMPLENIA_API_URL=https://api.implenia-messtechnik.example.com
IMPLENIA_API_KEY=your-bearer-token

# --- Self-Updater (GitHub Releases) ---
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
# Optional: token for private repos
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Check interval in ms (default: 1 hour)
UPDATE_CHECK_INTERVAL_MS=3600000

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Connectivity Probe ---
# DNS host used to check internet reachability
CONNECTIVITY_PROBE_HOST=8.8.8.8
# Poll interval in ms (default: 30 seconds)
CONNECTIVITY_POLL_INTERVAL_MS=30000
